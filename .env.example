# --- Neo4j (required for technique_statistics.py and mitigation_priority_scorer.py) ---
# Copy this file to .env and fill in real values. Never commit .env.
#
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# Use either NEO4J_USER or NEO4J_USERNAME (Aura often uses the instance id as user).
NEO4J_USER=neo4j
# NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password-or-aura-secret

# --- Optional: file paths (relative to repo root, or absolute) ---
# Output of technique_statistics.py (input to technique_priority_scorer.py)
# OUTPUT_TECHNIQUE_STATISTICS=input/technique_statistics.xlsx
#
# MCDM input/output
# INPUT_TECHNIQUE_STATISTICS=input/technique_statistics.xlsx
# OUTPUT_TECHNIQUE_PRIORITY_SCORES=output/technique_priority_scores.xlsx
#
# Mitigation ranking CLI
# INPUT_ATTACK_CHAIN_JSON=input/example_attack_chain.json
# INPUT_TECHNIQUE_PRIORITY_SCORES=output/technique_priority_scores.xlsx
# OUTPUT_MITIGATION_PRIORITY_SCORES=output/mitigation_priority_scores.xlsx
